<script>

let cart = [];

function addToCart(name, price){

cart.push({name, price});
updateCart();

}

function updateCart(){

let total = 0;
let list = "";

cart.forEach(item=>{
total += item.price;
list += item.name + " - " + item.price + "€<br>";
});

document.getElementById("cart-items").innerHTML = list;
document.getElementById("cart-total").innerHTML = total + "€";

}

</script>

<div style="position:fixed;bottom:20px;right:20px;background:#1c1c1c;padding:20px;border-radius:10px;width:250px;">

<h3>🛒 Panier</h3>

<div id="cart-items"></div>

<p>Total : <span id="cart-total">0€</span></p>

</div>
